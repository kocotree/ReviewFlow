# 飞书应用凭证
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 多维表格配置
BITABLE_APP_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BITABLE_TABLE_ID=tblxxxxxxxxxxxxxxxx
# 飞书租户域名（用于通知卡片中的记录跳转链接），形如 https://xxx.feishu.cn
# 留空则通知卡片不显示"查看记录"按钮。
FEISHU_BASE_URL=https://xxx.feishu.cn

# Webhook 配置（飞书开放平台事件订阅页面获取）
WEBHOOK_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxx
WEBHOOK_ENCRYPT_KEY=xxxxxxxxxxxxxxxx

# AI 配置
# 可选值: doubao（当前仅支持豆包，其余 provider 已下线）
#
# 文件/图片直传说明：
# - AI_MODEL 为支持文件模态的型号时，会把在线文档(导出为PDF)、PDF附件、图片附件
#   「直传」给模型；否则一律降级为文本抽取。
# - 已知支持文件模态(PDF)的豆包型号：doubao-seed-2.0-pro / 2.0-lite / 2.0-mini
#   系列（如 doubao-seed-2-0-pro-260428）。其他型号走纯文本评分。
# - docx/doc → PDF 转换依赖容器内的 LibreOffice（见 Dockerfile）；本地直接运行
#   需自行安装 soffice，否则 docx 会回退为 python-docx 抽文本。
AI_PROVIDER=doubao
AI_API_KEY=your-doubao-api-key
AI_MODEL=doubao-seed-2-0-pro-260215
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 评分采样温度：默认 0，走确定性采样以提高多次评分的一致性；越低越稳定
AI_TEMPERATURE=0
# 评分调用 max_tokens：评分响应仅含短 JSON，默认 4000 留足余量防截断
AI_SCORE_MAX_TOKENS=4000
# 文档转写调用 max_tokens：转写正文较长，默认 16000；截断只影响缓存不影响评分
AI_TRANSCRIBE_MAX_TOKENS=16000

# 评分配置
SCORE_THRESHOLD=70
MAX_REVISION_ROUNDS=5

# 通知配置
NOTIFICATION_COOLDOWN_MINUTES=60
MAX_DAILY_NOTIFICATIONS_PER_USER=3
# 异常/告警通知群的 chat_id（形如 oc_xxx）；为空则不向群推送。
# 机器人需已加入该群，否则发送会失败。
NOTIFICATION_GROUP_CHAT_ID=oc_a6603d7738306a0cce7e5afa8d17ffaa
# 发送侧防回声熔断：同一记录在窗口内最多发出的卡片数（不限制提报或重评）。
SEND_CIRCUIT_BREAKER_WINDOW_MINUTES=5
SEND_CIRCUIT_BREAKER_MAX_MESSAGES=20

# 服务配置
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
